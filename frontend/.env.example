# MedicX — Frontend Environment Variables (TEMPLATE)
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" in the same directory and edit
# the values you need. Variables prefixed with NEXT_PUBLIC_ are
# embedded at build time and visible in the browser bundle.
# ─────────────────────────────────────────────────────────────

# Backend API base URL. Defaults to http://localhost:8000 when
# not set, which matches the backend's `uvicorn` defaults. Change
# to your deployed backend (e.g. https://api.example.com) when
# building for production.
NEXT_PUBLIC_API_URL=http://localhost:8000
