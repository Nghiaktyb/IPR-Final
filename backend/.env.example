# MedicX — Environment Variables (TEMPLATE)
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" in the same directory and customise.
# Do NOT commit your real .env (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────
APP_NAME=MedicX — AI Radiology Diagnostic Suite
APP_VERSION=1.0.0
DEBUG=true

# ─── Database ─────────────────────────────────────────────────
# MySQL (recommended). Replace USER, PASS and host as needed.
DATABASE_URL=mysql+pymysql://USER:PASS@localhost:3306/medix

# Alternative engines:
# DATABASE_URL=sqlite:///./medix.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/medix

# ─── JWT Authentication ──────────────────────────────────────
# Generate a long random string. Anything 32+ chars is fine for dev.
SECRET_KEY=change-this-to-a-strong-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── AI Model (optional) ─────────────────────────────────────
# Path to the trained .pth checkpoint. Defaults to
# backend/models/medix_model.pth (created on first promote from the
# admin AI Training page). Override only if you keep the file
# elsewhere. If the file is missing the AI engine runs in
# simulation mode (random scores) — that's fine for UI testing.
# MODEL_PATH=C:/path/to/your/medix_model.pth

# ─── AI Inference Defaults ───────────────────────────────────
DEFAULT_THRESHOLD=0.5
IMAGE_SIZE=224

# ─── Data Retention (admin → Data Retention page) ───────────
# Default cutoff (years) used by the bulk purge slider.
DEFAULT_RETENTION_YEARS=7
RETENTION_MIN_YEARS=1
RETENTION_MAX_YEARS=30

# ─── CORS ────────────────────────────────────────────────────
# JSON-encoded list of allowed origins. Add your production
# frontend URL(s) here when deploying.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
