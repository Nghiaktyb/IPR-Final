# MedicX — Environment Variables
# Copy this to .env and customize

# Application
APP_NAME=MedicX — AI Radiology Diagnostic Suite
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./medix.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/medix

# JWT Authentication
SECRET_KEY=change-this-to-a-strong-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Model
DEFAULT_THRESHOLD=0.5
IMAGE_SIZE=224

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
