# ─── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual environments ────────────────────────────
.venv/
venv/
ENV/
env/

# ─── Secrets ─────────────────────────────────────────
