.env
.env.local
.env.production
backend/.env
frontend/.env.local
frontend/.env.production

# ─── Next.js / Node ──────────────────────────────────
.next/
out/
build/
node_modules/

# ─── OS files ────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── MedicX dynamic storage (per-machine) ────────────
backend/uploads/
backend/heatmaps/
backend/reports/
backend/training_data/
backend/training_runs/
backend/models/
backend/medix.db
backend/medix.db-journal
backend/*.sqlite
backend/*.sqlite3

# ─── ML / model checkpoints ──────────────────────────
*.pth
*.pt
*.ckpt
*.onnx

# ─── Logs ────────────────────────────────────────────
*.log
